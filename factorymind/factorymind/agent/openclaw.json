{
  "name": "factorymind-controller",
  "version": "0.1.0",
  "soul": "./SOUL.md",

  "models": {
    "providers": {
      "ollama-local": {
        "type": "openai-compatible",
        "baseUrl": "http://localhost:11434/v1",
        "models": [
          "nemotron-3-nano:30b"
        ]
      },
      "local-gb10-ar": {
        "type": "openai-compatible",
        "baseUrl": "http://localhost:8001/v1",
        "models": [
          "google/gemma-4-26B-A4B-it"
        ]
      }
    },
    "default": "ollama-local/nemotron-3-nano:30b",
    "fallback": "local-gb10-ar/google/gemma-4-26B-A4B-it"
  },

  "mcp": {
    "servers": {
      "factorymind-sim": {
        "transport": "http",
        "url": "http://localhost:8765/mcp",
        "description": "FactoryMind cell sim — tools: reset_cell, get_cell_state, step_cell, set_task, list_targets"
      }
    }
  },

  "skills": "./skills.yaml",

  "memory": {
    "enabled": true,
    "scope": "session",
    "include": ["latency_log"]
  },

  "shell": {
    "policy": "./openshell-policy.yaml",
    "network": {
      "allow": ["localhost:11434", "localhost:8765", "localhost:8766"],
      "deny": ["*"]
    },
    "filesystem": {
      "read": ["./"],
      "write": ["./telemetry/"]
    }
  }
}
